# Copy file này thành .env rồi điền giá trị thật.
#
# - Chạy bằng Node trực tiếp: server.js đọc DB_HOST/DB_USER/... qua process.env
#     node --env-file=.env server.js
# - Chạy bằng Docker: docker compose tự đọc file .env này
#     docker compose up -d --build

# --- Database ---
DB_NAME=knowledge_graph
DB_USER=kguser
DB_PASS=kgpass
# Chỉ dùng cho Docker (mật khẩu root của MySQL container):
MYSQL_ROOT_PASSWORD=rootpass

# Khi chạy Node KHÔNG dùng Docker, đặt thêm:
DB_HOST=localhost
DB_PORT=3306

# --- App ---
PORT=3000
# Cổng publish ra host khi dùng Docker (mặc định 3000):
APP_PORT=3000

# Token bảo mật (để trống = tắt). Nếu đặt, phải khớp const API_TOKEN trong public/index.html
API_TOKEN=

# --- Đăng nhập (bắt buộc) ---
AUTH_USER=admin
AUTH_PASS=changeme
# Khóa ký cookie phiên: đặt chuỗi ngẫu nhiên dài, cố định (vd: openssl rand -hex 32).
# Để trống = sinh tạm mỗi lần khởi động (mọi người bị đăng xuất khi server restart).
SESSION_SECRET=
# Thời hạn phiên tính bằng giờ (mặc định 168 = 7 ngày):
SESSION_TTL_HOURS=168
# Đặt true khi chạy sau HTTPS (vd: bản prod có Caddy) để cookie chỉ gửi qua https:
COOKIE_SECURE=false
